# ============================================
# Futebol Milhão - Variáveis de Ambiente
# ============================================
# Copie este arquivo para .env e preencha com
# seus valores reais. NUNCA commite o .env!
#
# Todas as variáveis expostas ao frontend usam
# o prefixo VITE_. Sem esse prefixo, o Vite NÃO
# as expõe ao navegador.
# ============================================

# Supabase (chave ANON / publishable)
# Esta é a chave pública. Segura para frontend.
VITE_SUPABASE_URL=https://SEU_PROJETO.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxx

# WhatsApp (dados de contato do admin)
VITE_ADMIN_WHATSAPP=5591900000000
VITE_WHATSAPP_GROUP_LINK=https://chat.whatsapp.com/SEU_GRUPO

# OneSignal (notificações push - opcional)
# Deixe vazio para desativar
VITE_ONESIGNAL_APP_ID=
# URL da Edge Function do Supabase (para enviar notificacoes)
VITE_SUPABASE_FUNCTIONS_URL=https://SEU_PROJETO.supabase.co/functions/v1
